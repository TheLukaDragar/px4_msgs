# ESC Beep Control
# Triggers ESC beacon sequences by ID

uint64 timestamp        # time since system start (microseconds)

uint8 beep_id           # ID of the beep sequence to play

# Beep sequence IDs
uint8 BEEP_ID_STOP = 0
uint8 BEEP_ID_PLACEHOLDER1 = 1
uint8 BEEP_ID_PLACEHOLDER2 = 2
uint8 BEEP_ID_PLACEHOLDER3 = 3
uint8 BEEP_ID_PLACEHOLDER4 = 4
